<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.hopital.controller.StatistiquesController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Tableau de bord" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- ===== CARTES DE CHIFFRES CLÉS ===== -->
    <HBox spacing="30">
        <VBox spacing="5" alignment="CENTER">
            <Label text="Total patients" />
            <Label fx:id="labelTotalPatients" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>

        <VBox spacing="5" alignment="CENTER">
            <Label text="Total rendez-vous" />
            <Label fx:id="labelTotalRdv" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold;"/>
        </VBox>
    </HBox>

    <Separator/>

    <!-- ===== TAUX DE PATIENTS ACTIFS ===== -->
    <Label text="Taux de patients actifs :"/>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <ProgressBar fx:id="progressActifs" prefWidth="300"/>
        <Label fx:id="labelPourcentageActifs" text="0 %"/>
    </HBox>

    <Separator/>

    <!-- ===== RÉPARTITION PAR STATUT ===== -->
    <Label text="Répartition des rendez-vous par statut :"/>
    <VBox spacing="8">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Planifié :" prefWidth="100"/>
            <ProgressBar fx:id="progressPlanifie" prefWidth="250"/>
            <Label fx:id="labelPlanifie" text="0"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Confirmé :" prefWidth="100"/>
            <ProgressBar fx:id="progressConfirme" prefWidth="250"/>
            <Label fx:id="labelConfirme" text="0"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Annulé :" prefWidth="100"/>
            <ProgressBar fx:id="progressAnnule" prefWidth="250"/>
            <Label fx:id="labelAnnule" text="0"/>
        </HBox>
    </VBox>

    <Button text="Actualiser" onAction="#actualiser"/>

</VBox>